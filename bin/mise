#!/usr/bin/env sh
# =============================================================
# bin/mise — Bootstrap script
# Generated by: mise generate bootstrap
# Committed to repo — zero prerequisites for the team
#
# Same pattern as mvnw / gradlew — your Java devs know this.
#
# What this does:
#   1. Checks if mise is already installed
#   2. If not, downloads and installs it locally in .mise/
#   3. Does NOT touch your global shell or PATH
#   4. Works on macOS, Linux, Windows (WSL/Git Bash)
# =============================================================

set -e

MISE_VERSION="${MISE_VERSION:-2026.4.8}"
MISE_INSTALL_PATH="${MISE_INSTALL_PATH:-.mise/mise}"

if [ -f "$MISE_INSTALL_PATH" ]; then
  exec "$MISE_INSTALL_PATH" "$@"
fi

echo ""
echo "mise not found locally — installing v$MISE_VERSION into .mise/"
echo "This does NOT modify your global shell or PATH."
echo ""

mkdir -p "$(dirname "$MISE_INSTALL_PATH")"

PLATFORM="$(uname -s)"
ARCH="$(uname -m)"

case "$PLATFORM" in
  Linux)
    case "$ARCH" in
      x86_64)  PLATFORM_SUFFIX="linux-x64" ;;
      aarch64) PLATFORM_SUFFIX="linux-arm64" ;;
      *)        echo "Unsupported arch: $ARCH"; exit 1 ;;
    esac
    ;;
  Darwin)
    case "$ARCH" in
      x86_64)  PLATFORM_SUFFIX="macos-x64" ;;
      arm64)   PLATFORM_SUFFIX="macos-arm64" ;;
      *)        echo "Unsupported arch: $ARCH"; exit 1 ;;
    esac
    ;;
  *)
    echo "Unsupported platform: $PLATFORM"
    echo "Windows users: run bin/setup.ps1 in PowerShell"
    exit 1
    ;;
esac

URL="https://github.com/jdx/mise/releases/download/v${MISE_VERSION}/mise-v${MISE_VERSION}-${PLATFORM_SUFFIX}"

if command -v curl >/dev/null 2>&1; then
  curl -fsSL "$URL" -o "$MISE_INSTALL_PATH"
elif command -v wget >/dev/null 2>&1; then
  wget -qO "$MISE_INSTALL_PATH" "$URL"
else
  echo "Error: curl or wget required"
  exit 1
fi

chmod +x "$MISE_INSTALL_PATH"
echo "mise v$MISE_VERSION installed at $MISE_INSTALL_PATH"
echo ""

exec "$MISE_INSTALL_PATH" "$@"
