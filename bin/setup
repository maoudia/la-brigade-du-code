#!/usr/bin/env sh
# =============================================================
# bin/setup — One command after git clone
# Works on macOS, Linux, Windows (WSL/Git Bash)
# =============================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

MIN_GIT_MAJOR=2
MIN_GIT_MINOR=40
MIN_DOCKER_MAJOR=28
MIN_COMPOSE_MAJOR=2

echo ""
echo "${BLUE}=======================================${NC}"
echo "${BLUE}   La Brigade du Code \U0001f373${NC}"
echo "${BLUE}   Pre-flight Check${NC}"
echo "${BLUE}=======================================${NC}"
echo ""

ERRORS=0

# --- Check git ---
if command -v git >/dev/null 2>&1; then
  GIT_VERSION=$(git --version | awk '{print $3}')
  echo "  ${GREEN}\u2713${NC} git             $GIT_VERSION"
else
  echo "  ${RED}\u2717${NC} git             not found"
  echo "    ${YELLOW}\u2192${NC} Install from https://git-scm.com"
  ERRORS=$((ERRORS + 1))
fi

# --- Check docker ---
if command -v docker >/dev/null 2>&1; then
  DOCKER_VERSION=$(docker --version 2>/dev/null | awk '{print $3}' | tr -d ',')
  echo "  ${GREEN}\u2713${NC} docker          $DOCKER_VERSION"
else
  echo "  ${RED}\u2717${NC} docker          not found"
  echo "    ${YELLOW}\u2192${NC} Install from https://docs.docker.com/get-docker/"
  ERRORS=$((ERRORS + 1))
fi

# --- Check docker compose ---
if docker compose version >/dev/null 2>&1; then
  COMPOSE_VERSION=$(docker compose version 2>/dev/null | awk '{print $4}')
  echo "  ${GREEN}\u2713${NC} docker compose  $COMPOSE_VERSION"
else
  echo "  ${RED}\u2717${NC} docker compose  not found"
  echo "    ${YELLOW}\u2192${NC} Included with Docker Desktop >= 4.x"
  ERRORS=$((ERRORS + 1))
fi

echo ""

if [ "$ERRORS" -gt 0 ]; then
  echo "${RED}Please install the missing tools above, then re-run ./bin/setup${NC}"
  exit 1
fi

echo "${YELLOW}\U0001f50d Checking mise...${NC}"

if command -v mise >/dev/null 2>&1; then
  echo "  ${GREEN}\u2713${NC} mise            $(mise --version) (global)"
else
  echo "  ${YELLOW}\u26a0${NC}  mise not found globally — using local bootstrap"
  echo "  ${YELLOW}\u2192${NC}  Installing mise locally in .mise/ (no global changes)"
  echo ""
  ./bin/mise --version >/dev/null 2>&1
  echo "  ${GREEN}\u2713${NC} mise            $(./bin/mise --version) (local)"
fi

echo ""
echo "${YELLOW}\U0001f4e6 Installing tools from mise.toml...${NC}"
echo ""

./bin/mise install

echo ""
echo "${YELLOW}\U0001f511 Trusting mise config...${NC}"
./bin/mise trust

echo ""
./bin/mise run banner

echo ""
echo "${GREEN}\u2713 Setup complete! You are ready to cook.${NC}"
echo ""
echo "Quick start:"
echo "  ./bin/mise run service    # start backend + frontend"
echo "  ./bin/mise run docker     # start with Docker Compose"
echo "  ./bin/mise tasks          # list all available tasks"
echo ""
