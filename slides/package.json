{
  "name": "brigade-slides",
  "version": "0.1.0",
  "private": true,
  "description": "La Brigade du Code — reveal.js slides (Markdown source, built with reveal-md)",
  "scripts": {
    "dev": "reveal-md slides.md --theme theme/brigade.css -w",
    "build": "reveal-md slides.md --theme theme/brigade.css --static _dist --assets theme",
    "pdf": "reveal-md slides.md --theme theme/brigade.css --print ../slides.pdf --print-size A4"
  },
  "devDependencies": {
    "reveal-md": "6.1.4"
  }
}
